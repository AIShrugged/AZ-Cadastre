# ── Service ─────────────────────────────────────────────────────────────────
SERVICE_PORT=3000
SERVICE_HOST=0.0.0.0

# Origin of the web app, allowed by CORS (API + presigned bucket uploads)
WEB_ORIGIN=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=cadastre-db

# ── Object storage (Garage / S3) ────────────────────────────────────────────
# Endpoint must be reachable from BOTH this service and the browser, since the
# presigned URL points straight at it. For local Garage that's localhost:3900.
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=documents
# Create a key with:  garage key create   /   grant it access to the bucket.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=600
