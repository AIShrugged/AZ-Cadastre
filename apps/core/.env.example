# ── Service ─────────────────────────────────────────────────────────────────
SERVICE_PORT=3000
SERVICE_HOST=0.0.0.0

# Origin of the web app, allowed by CORS (API + presigned bucket uploads)
WEB_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Canonical connection string, consumed by both Prisma and the app.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cadastre-db?schema=public

# ── Object storage (RustFS / S3) ───────────────────────────────────────────
# Endpoint must be reachable from BOTH this service and the browser, since the
# presigned URL points straight at it. For local RustFS that's localhost:9000.
S3_ENDPOINT=http://localhost:9000
S3_REGION=rustfs
S3_BUCKET=documents
# S3 access credentials for RustFS.
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=600
