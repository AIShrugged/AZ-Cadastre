// The verification report (PRD §5): the pipeline's final output for a package.
// One report per package (1:1), holding the overall outcome; the individual
// findings live in ValidationIssue.

/// Overall verification *outcome* — distinct from PackageStatus (pipeline
/// lifecycle). Computed by the validation engine from the issues found.
enum ReportStatus {
  OK // no issues
  IssuesFound // validation issues present
  IncompletePackage // required documents missing
}

model Report {
  id        String              @id @default(uuid()) @db.Uuid
  packageId String              @unique @db.Uuid // 1:1 with the package
  package   VerificationPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  status ReportStatus

  issues ValidationIssue[]

  generatedAt DateTime @default(now())

  @@map("reports")
}
