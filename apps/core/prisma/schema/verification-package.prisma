// Aggregate root: a Verification Package — one upload of one or more files.
// Each file becomes exactly one Document (PRD §3).

/// Pipeline lifecycle of a package — distinct from the verification *outcome*
/// (OK / Issues Found / Incomplete), which belongs to the Report aggregate.
enum PackageStatus {
  Pending // uploaded, pipeline not started
  Processing // pipeline running (OCR → classify → extract → validate)
  Completed // pipeline finished, report available
  Failed // pipeline hit a permanent error
}

model VerificationPackage {
  id        String        @id @default(uuid()) @db.Uuid
  status    PackageStatus @default(Pending)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  documents Document[]

  @@map("verification_packages")
}
